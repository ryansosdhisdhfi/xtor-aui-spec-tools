# 复制为 secrets.sh 后填写:  cp secrets.sh.example secrets.sh
# secrets.sh 不要提交到 Git（见本目录 .gitignore）。

# OpenAI 兼容 API（与 aidoc_*.py / batch_describe 一致）
export API_URL="https://example.com/v1"
export API_KEY="在此填写"
export MODEL="gpt-5.4"

# batch_describe.py 的 --base-url（不要带 /v1；若不设会自动从 API_URL 去掉末尾的 /v1）
# export BATCH_BASE_URL="https://example.com"
