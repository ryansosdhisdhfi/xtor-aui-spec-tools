# 复制为 secrets.sh 后填写 API_KEY，勿提交 secrets.sh（见 .gitignore）
# API_KEY 须为英文/数字/常见符号；勿用中文占位句，否则 HTTP 头 latin-1 编码会报 UnicodeEncodeError。
#   cp secrets.sh.example secrets.sh
#
# 说明：本仓库里 aidoc_* 使用 **OpenAI Chat Completions** 协议，请求为：
#   {API_URL}/chat/completions
# 因此 API_URL 请写到 **/v1** 为止，不要带 /responses。
# 你控制台若显示 base 为 https://backend.intelalloc.com/v1/responses，多为「产品页展示」的
# Responses API；与 Makefile 里脚本对接时，仍请用下面这种 **/v1**（除非 IntelAlloc 文档明确要求其它路径）。

export API_URL="https://backend.intelalloc.com/v1"
export API_KEY="sk-fc240c95e1c7e6b9c9222d9308f16aa491e190f679e856dc1a904aed458a7fb4"
export MODEL="gpt-5.4"
# 网关偶发 502/429 时，aidoc_llm 与 B5 VLM（figure_describe）对单次请求自动重试（默认 8，可覆盖，上限 30）
# export AIDOC_LLM_MAX_RETRIES=12
# B5 单次 VLM 读超时（秒，默认 600）；大图/慢网关可调大
# export AIDOC_VLM_TIMEOUT_SEC=1200
# b7 aidoc_index：摘要输入默认不截断全文；仅当网关有 context 硬上限时再设（正整数=最多字符）
# export AIDOC_INDEX_MAX_CHUNK_CHARS=80000

# 以下为你在其它 JSON/客户端里可能用到的项；aidoc 当前脚本**不会自动读取**，
# 需要时可在自写封装里用，或保留作备忘。
# export REASONING_EFFORT="medium"
# export WEB_SEARCH="true"

# 图链 B5：与 a2–a4 相同，使用 Chat Completions + vision，OpenAI 客户端 base 须为「…/v1」
# 默认与 API_URL 一致 — Makefile 已传完整 API_URL；仅当 B5 需换主机时再设:
# export BATCH_BASE_URL="https://other.example.com/v1"

